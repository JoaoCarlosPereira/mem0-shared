USER=user

# --- Memória Central Compartilhada (local-first) ---------------------------
# Instalação única na rede local: API/MCP + Qdrant em container + Ollama local.
# Operação 100% local — nenhuma dependência de serviços fora da rede (privacidade).
#
# --- Garantias fail-closed (não desligar em deploy de time) ----------------
# MEM0_LOCAL_ONLY=1: o servidor RECUSA inicializar o cliente de memória se o
#   LLM/embedder configurado apontar para um host não-local (ex.: api.openai.com,
#   anthropic, etc.). Garante, em código, que o conteúdo das memórias nunca sai
#   da rede local — independente do que estiver no DB/env.
# MEM0_TELEMETRY=false: desliga os eventos de uso (PostHog) do core do mem0
#   neste processo. Com MEM0_LOCAL_ONLY=1, o servidor força isto de qualquer forma.
MEM0_LOCAL_ONLY=1
MEM0_TELEMETRY=false
#
# Fail-closed: bloqueia exclusão de memórias via API/MCP (padrão seguro).
# Só habilite deliberadamente quando precisar apagar memórias manualmente.
# MEM0_ALLOW_MEMORY_DELETE=0
# MEM0_ALLOW_BULK_DELETE=0
#
# OPENAI_API_KEY NÃO é necessária no fluxo local-first (LLM/embedder via Ollama).
# Defina-a apenas se trocar LLM_PROVIDER/EMBEDDER_PROVIDER para 'openai'.
# OPENAI_API_KEY=

# LLM/Embedder local-first. O setup (task_09) detecta os modelos e escolhe o
# backend automaticamente. Dois backends locais são suportados:
#
#   Ollama (default):  GET /api/tags
#   llama.cpp:         servidor OpenAI-compatível, GET /v1/models
#
# --- Backend Ollama (default) ---
LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:latest
# LLM_API_KEY=
# LLM_BASE_URL=
OLLAMA_BASE_URL=http://host.docker.internal:11434

EMBEDDER_PROVIDER=ollama
# EMBEDDER_MODEL=nomic-embed-text
# EMBEDDER_API_KEY=
# EMBEDDER_BASE_URL=

# --- Backend llama.cpp (alternativa) ---
# llama.cpp não tem provider nativo no mem0; usa-se o provider `openai` apontando
# para o servidor local OpenAI-compatível. O instalador preenche isto ao detectar
# o llama.cpp. Exemplo (servidor em http://host.docker.internal:8080):
#   LLM_PROVIDER=openai
#   LLM_MODEL=<id do /v1/models>
#   LLM_BASE_URL=http://host.docker.internal:8080/v1
#   LLM_API_KEY=llama.cpp
#   EMBEDDER_PROVIDER=openai
#   EMBEDDER_MODEL=<id do /v1/models>
#   EMBEDDER_BASE_URL=http://host.docker.internal:8080/v1
#   EMBEDDER_API_KEY=llama.cpp

# Vector store: Qdrant em container (coleção única — ADR-003).
# No docker-compose estes valores já apontam para o serviço `mem0_store`.
QDRANT_HOST=mem0_store
QDRANT_PORT=6333

# Banco relacional (catálogo de projetos + fila de escrita + histórico).
# Persistido via bind mount ./api no compose.
DATABASE_URL=sqlite:////usr/src/openmemory/openmemory.db

# Auto-descoberta MCP (task_08): URL base anunciada no GET /discovery.
# Opcional — quando ausente, é derivada da requisição recebida.
# Em escala, aponte para o reverse proxy (entrypoint único):
# OPENMEMORY_DISCOVERY_BASE_URL=http://192.168.0.10:8765

# --- Modo escala (docker-compose.scale.yml) --------------------------------
# PostgreSQL via PgBouncer (transaction mode):
# DATABASE_URL=postgresql://mem0:mem0@pgbouncer:5432/openmemory
# POSTGRES_USER=mem0
# POSTGRES_PASSWORD=mem0
# POSTGRES_DB=openmemory
# PGBOUNCER_PORT=6432
#
# Redis (cache de embedding + busca):
# REDIS_URL=redis://redis:6379/0
# REDIS_EMBED_TTL=3600
# REDIS_SEARCH_TTL=300
#
# Serviços de inferência dedicados (ADR-002):
# OLLAMA_EMBED_URL=http://ollama-embed:11434
# OLLAMA_LLM_URL=http://ollama-llm:11434
#
# Worker embutido na API (dev=true, escala=false):
# RUN_EMBEDDED_WORKER=false
# WRITE_WORKER_MAX_CONCURRENCY=1
# WRITE_WORKER_BATCH_SIZE=1
# WRITE_WORKER_MAX_ATTEMPTS=3
# WRITE_WORKER_FAILED_RETRY_AFTER_MINUTES=15
#
# Backup autônomo (task_06 / ADR-002, ADR-003):
# LOCAL_BACKUP_DIR é interpolado pelo docker-compose.scale.yml (lido de
# openmemory/.env ou do shell) e monta o diretório do HOST em /mnt/backups
# dentro da API/worker. A UI e a política usam o caminho do HOST (ex. abaixo);
# a API traduz internamente para /mnt/backups.
# LOCAL_BACKUP_DIR=/mnt/dados/backups
# BACKUP_WORKER_SLEEP=300   # intervalo (s) entre verificações de agenda do worker

# --- Autenticação Google + identidade (feature auth Google) ----------------
# Login com Google na UI + token de agente (?token= na URL MCP). Sem estas
# variáveis o login fica desabilitado (fail-closed) e o fluxo legado por
# hostname continua funcionando normalmente.
#
# Dois fluxos coexistem (ADR-009):
#   1. Redirect (primário) — UI publicada em https://memorias.sysmo.com.br via
#      Traefik; credencial Google tipo "Aplicativo da Web" com redirect
#      <URL_DA_UI>/api/auth/callback/google (tela de permissão: Interno).
#   2. Device flow (alternativa) — código em google.com/device; credencial tipo
#      "TVs e dispositivos de entrada limitada" (sem URL de redirect).
#
# API (docker-compose.scale.yml, bloco x-api-env):
# AUTH_JWT_SECRET=            # assina o JWT de sessão da UI; >= 32 bytes aleatórios
# AUTH_ALLOWED_DOMAIN=        # domínio Google Workspace da empresa (ex.: sysmo.com.br)
# GOOGLE_CLIENT_ID=           # client OAuth "Aplicativo da Web" (redirect)
# GOOGLE_CLIENT_SECRET=
# GOOGLE_DEVICE_CLIENT_ID=    # client OAuth "TVs" (device flow) — opcional;
# GOOGLE_DEVICE_CLIENT_SECRET=  # sem ele, o device flow usa o par principal
#
# UI (serviço openmemory-ui):
# GOOGLE_CLIENT_SECRET=       # o mesmo client secret Web (provider NextAuth)
# NEXTAUTH_SECRET=            # segredo da sessão NextAuth; >= 32 bytes aleatórios
# NEXTAUTH_URL=https://memorias.sysmo.com.br   # URL pública da UI
#
# HTTPS da UI (Traefik, ADR-009):
# UI_HOSTNAME=memorias.sysmo.com.br   # rota Host() no entrypoint :443
# TLS_CERT_DIR=                        # dir com ui.crt/ui.key (default openmemory/certs)
# PROXY_TLS_PORT=443                   # porta TLS publicada no host
#
# Deploy da feature (regras CRITICAL do repo):
# 1) migração manual:  docker compose -f docker-compose.scale.yml run --rm --no-deps openmemory-mcp alembic upgrade head
# 2) rebuild SOMENTE de openmemory-mcp, openmemory-write-worker e openmemory-ui
#    (nunca recriar mem0_store/postgres; conferir points_count do Qdrant antes/depois)
